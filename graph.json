{
  "start": {"type": "MANUAL"},
  "nodes": [
    {
      "id": "intake",
      "type": "FORM",
      "label": "Intake",
      "config": {
        "input_schema": {
          "type": "object",
          "properties": {
            "subject": {"type": "string"},
            "body":    {"type": "string"}
          },
          "required": ["subject", "body"]
        }
      }
    },
    {
      "id": "triage",
      "type": "AGENT",
      "label": "Triage",
      "config": {
        "agent_name": "triage-agent",
        "input_mapping": {
          "subject": {"type": "expression", "value": "intake.subject"},
          "body":    {"type": "expression", "value": "intake.body"}
        }
      }
    },
    {
      "id": "save",
      "type": "FUNCTION",
      "label": "Save Result",
      "config": {
        "function_name": "save_triage_result",
        "input_mapping": {
          "record_id":  {"type": "expression", "value": "intake.id"},
          "category":   {"type": "expression", "value": "triage.category"},
          "priority":   {"type": "expression", "value": "triage.priority"},
          "draft_reply":{"type": "expression", "value": "triage.draft_reply"}
        }
      }
    },
    {
      "id": "end",
      "type": "END",
      "label": "Done"
    }
  ],
  "edges": [
    {"id": "e1", "source": "intake",  "target": "triage"},
    {"id": "e2", "source": "triage",  "target": "save"},
    {"id": "e3", "source": "save",    "target": "end"}
  ]
}